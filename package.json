{
  "name": "the-librarian",
  "version": "0.1.0",
  "description": "A portable, agent-agnostic memory system for AI agents.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "prepare": "lefthook install",
    "start": "pnpm --filter @librarian/mcp-server start",
    "serve": "pnpm --filter @librarian/mcp-server serve",
    "dashboard": "pnpm --filter @librarian/mcp-server serve",
    "rebuild": "pnpm --filter @librarian/cli rebuild",
    "seed": "pnpm --filter @librarian/cli seed",
    "test": "pnpm -r run build && pnpm -r run test:vitest && vitest run",
    "smoke": "node --no-warnings scripts/smoke-test.js",
    "healthcheck": "node --no-warnings scripts/healthcheck.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm -r run build",
    "check:test-count": "node --no-warnings scripts/check-test-count.mjs",
    "check:storage-fixture": "node --no-warnings scripts/check-storage-fixture.mjs",
    "check:schema-version": "node --no-warnings scripts/check-schema-version.mjs",
    "check:session-state-divergence": "node --no-warnings scripts/check-session-state-divergence.mjs"
  },
  "engines": {
    "node": ">=22.5.0",
    "pnpm": ">=9.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@librarian/cli": "workspace:*",
    "@librarian/core": "workspace:*",
    "@vitest/eslint-plugin": "^1.1.40",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unicorn": "^57.0.0",
    "globals": "^15.14.0",
    "lefthook": "^1.10.10",
    "prettier": "^3.4.2",
    "typescript": "catalog:",
    "typescript-eslint": "^8.19.0",
    "vitest": "catalog:"
  },
  "license": "Apache-2.0"
}
