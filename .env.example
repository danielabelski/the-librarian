# MCP admin token. The dashboard itself is not token-authenticated.
LIBRARIAN_ADMIN_TOKEN=replace-with-a-long-random-admin-token
LIBRARIAN_AGENT_TOKEN=replace-with-a-different-long-random-agent-token

# Optional stronger isolation for agent-private memories. Prefer this over a
# shared LIBRARIAN_AGENT_TOKEN when multiple agents should not impersonate each
# other. Format: agent_id:token,agent_id:token
LIBRARIAN_AGENT_TOKENS=

# Bind to 127.0.0.1 by default. For direct Tailnet access, set this to the
# VPS Tailscale IP, for example 100.x.y.z.
LIBRARIAN_PUBLISHED_HOST=127.0.0.1

# Optional comma-separated browser origins allowed to call POST endpoints.
# Same-origin browser requests are allowed by default. If you access through an
# HTTPS reverse proxy or alternate hostname, set that exact origin.
LIBRARIAN_ALLOWED_ORIGINS=
