{
  "name": "@librarian/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "stdio + HTTP MCP server plus tRPC admin API for The Librarian.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prepare": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "start": "node --no-warnings dist/bin/stdio.js",
    "serve": "node --no-warnings dist/bin/http.js",
    "test:node": "node --no-warnings --test tests/*.test.js",
    "test:vitest": "vitest run",
    "test": "pnpm run build && pnpm run test:node && pnpm run test:vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@librarian/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "Apache-2.0"
}
